{
  "name": "chinmeister",
  "version": "0.1.0",
  "description": "Vendor-neutral control layer for agentic development: shared memory, coordination, MCP-first",
  "type": "module",
  "bin": {
    "chinmeister": "./dist/cli.js"
  },
  "scripts": {
    "build": "esbuild cli.tsx --bundle --platform=node --format=esm --banner:js='#!/usr/bin/env node' --outfile=dist/cli.js --sourcemap --external:ink --external:react --external:ink-text-input --external:node-pty --external:better-sqlite3 --resolve-extensions=.ts,.tsx,.js,.jsx,.json",
    "dev": "npm run build && node dist/cli.js",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@chinmeister/shared": "file:../shared",
    "chalk": "^5.6.2",
    "chinmeister-mcp": "file:../mcp",
    "ink": "^5.1.0",
    "ink-text-input": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "mcp",
    "cli",
    "ai",
    "agents",
    "cursor",
    "claude",
    "coordination",
    "developer-tools"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
