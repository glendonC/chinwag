{
  "name": "chinwag-monorepo",
  "private": true,
  "workspaces": [
    "packages/cli",
    "packages/worker",
    "packages/mcp"
  ],
  "scripts": {
    "build:vscode": "esbuild packages/vscode/extension.js --bundle --platform=node --format=cjs --outfile=packages/vscode/dist/extension.js --external:vscode",
    "dev:cli": "npm run dev --workspace=packages/cli",
    "dev:worker": "npm run dev --workspace=packages/worker",
    "deploy": "npm run deploy --workspace=packages/worker",
    "test": "npm run test --workspaces --if-present && npm run test:web",
    "test:worker": "npm run test --workspace=packages/worker",
    "test:mcp": "npm run test --workspace=packages/mcp",
    "test:cli": "npm run test --workspace=packages/cli",
    "test:web": "npm run test --prefix packages/web",
    "dev:web": "npm run dev --prefix packages/web",
    "dev:web:static": "npm run dev:static --prefix packages/web",
    "dev:web:py": "python3 packages/web/serve.py",
    "og-image": "npm exec --yes --package=@resvg/resvg-js@2.4.0 -- node packages/web/scripts/render-og-image.mjs"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
